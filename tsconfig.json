{
  "compilerOptions": {
    "module": "esnext",
    "target": "ES2024",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "erasableSyntaxOnly": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2024"],
    "types": ["node"],
    "moduleResolution": "bundler"
  }
}
