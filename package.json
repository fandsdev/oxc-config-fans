{
  "name": "oxc-config-fans",
  "version": "0.0.2",
  "description": "Opinionated OXC (oxlint + oxfmt) shareable configs by FANS",
  "license": "MIT",
  "author": "Eduard Aksamitov <e@euaaaio.ru>",
  "repository": "fandsdev/oxc-config-fans",
  "type": "module",
  "exports": {
    "./oxfmt": {
      "types": "./src/oxfmt/index.d.ts",
      "import": "./src/oxfmt/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint/index.d.ts",
      "import": "./src/oxlint/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "test:format": "oxfmt --check",
    "test:types": "tsc --noEmit",
    "test:lint": "oxlint",
    "test:dedupe": "pnpm dedupe --check",
    "test": "pnpm run /^test:/",
    "build": "tsx scripts/oxgen.ts",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.4.1",
    "@oxlint/migrate": "1.61.0",
    "@tanstack/eslint-plugin-query": "^5.100.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-fans": "github:fandsdev/eslint-config-fans#next",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-de-morgan": "^2.1.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@e18e/eslint-plugin": "^0.4.1",
    "@tanstack/eslint-plugin-query": "^5.100.6",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-de-morgan": "^2.1.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1"
  },
  "peerDependenciesMeta": {
    "@e18e/eslint-plugin": {
      "optional": true
    },
    "@tanstack/eslint-plugin-query": {
      "optional": true
    },
    "eslint-plugin-astro": {
      "optional": true
    },
    "eslint-plugin-perfectionist": {
      "optional": true
    },
    "eslint-plugin-vuejs-accessibility": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,json,md,yml,yaml}": "oxfmt"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
