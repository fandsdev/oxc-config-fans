{
  "name": "oxc-config-fans",
  "version": "0.0.1",
  "description": "Opinionated oxfmt shareable config by FANS",
  "license": "MIT",
  "author": "Eduard Aksamitov <e@euaaaio.ru>",
  "repository": "fandsdev/oxc-config-fans",
  "type": "module",
  "exports": {
    "./oxfmt": {
      "types": "./src/oxfmt/index.d.ts",
      "import": "./src/oxfmt/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "test:format": "oxfmt --check",
    "test:types": "tsc --noEmit",
    "test:dedupe": "pnpm dedupe --check",
    "test": "pnpm run /^test:/",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.47.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "oxfmt": "^0.47.0"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,json,md,yml,yaml}": "oxfmt"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
