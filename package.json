{
  "name": "oxc-config-fans",
  "version": "0.0.6",
  "description": "Opinionated OXC (oxlint + oxfmt) shareable configs by FANS",
  "license": "MIT",
  "author": "Eduard Aksamitov <e@euaaaio.ru>",
  "repository": "fandsdev/oxc-config-fans",
  "type": "module",
  "exports": {
    "./oxfmt": {
      "types": "./src/oxfmt/index.d.ts",
      "import": "./src/oxfmt/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint/index.d.ts",
      "import": "./src/oxlint/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "test:format": "oxfmt --check",
    "test:types": "tsc --noEmit",
    "test:lint": "oxlint",
    "test:dedupe": "pnpm dedupe --check",
    "test": "pnpm run /^test:/",
    "build": "node --experimental-strip-types scripts/oxgen.ts",
    "check:react-compiler": "node --experimental-strip-types scripts/check-react-compiler-rules.ts",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.0",
    "@oxlint/migrate": "1.68.0",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-fans": "^1.11.0",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@e18e/eslint-plugin": ">=0.4.1",
    "@tanstack/eslint-plugin-query": ">=5.100.6",
    "eslint-plugin-de-morgan": ">=2.1.1",
    "eslint-plugin-perfectionist": ">=5.9.0",
    "eslint-plugin-react-hooks": ">=7.1.1",
    "eslint-plugin-vuejs-accessibility": ">=2.5.0",
    "oxfmt": ">=0.47.0",
    "oxlint": ">=1.61.0",
    "oxlint-tsgolint": ">=0.21.1"
  },
  "peerDependenciesMeta": {
    "@tanstack/eslint-plugin-query": {
      "optional": true
    },
    "eslint-plugin-perfectionist": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-vuejs-accessibility": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,json,md,yml,yaml}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
